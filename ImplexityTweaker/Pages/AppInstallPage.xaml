<Page x:Class="ImplexityTweaker.Pages.AppInstallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Apps"
      Foreground="{DynamicResource App.Text}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Установка приложений" FontSize="32" FontWeight="Bold" />
            <TextBlock Text="Пакеты через winget (нужен установленный App Installer / winget)."
                       Foreground="{DynamicResource App.TextMuted}"
                       Margin="0,8,0,16"
                       TextWrapping="Wrap" />

            <ui:Card>
                <StackPanel Margin="16">
                    <ui:Button Content="Базовый набор: Chrome, 7-Zip, VLC, VS Code"
                               Appearance="Primary"
                               HorizontalAlignment="Left"
                               Click="Bundle_Click" />
                    <TextBlock Text="Ещё популярные приложения" Margin="0,16,0,8"
                               Foreground="{DynamicResource App.TextMuted}" />
                    <ui:Button Content="Установить Firefox" Appearance="Secondary" Click="Firefox_Click" HorizontalAlignment="Left" Margin="0,0,0,8" />
                    <ui:Button Content="Установить Steam" Appearance="Secondary" Click="Steam_Click" HorizontalAlignment="Left" Margin="0,0,0,8" />
                    <ui:Button Content="Установить Discord" Appearance="Secondary" Click="Discord_Click" HorizontalAlignment="Left" Margin="0,0,0,8" />
                    <ui:Button Content="Установить Telegram Desktop" Appearance="Secondary" Click="Telegram_Click" HorizontalAlignment="Left" Margin="0,0,0,8" />
                    <ui:Button Content="Открыть GitHub: zapret-discord-youtube" Appearance="Transparent"
                               HorizontalAlignment="Left"
                               Click="OpenZapretGithub_Click"
                               Margin="0,10,0,0" />
                    <TextBlock Text="Ручная установка по winget ID:"
                               Margin="0,12,0,4"
                               Foreground="{DynamicResource App.TextMuted}" />
                    <TextBox x:Name="ManualWingetIdBox" MinWidth="380" Text="Microsoft.PowerToys" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <ui:Button Content="Установить ID"
                                   Appearance="Secondary"
                                   Click="InstallManual_Click" />
                        <ui:Button Content="Обновить все пакеты"
                                   Margin="8,0,0,0"
                                   Appearance="Transparent"
                                   Click="UpgradeAll_Click" />
                    </StackPanel>
                    <ui:Button Content="Открыть поиск winget (консоль)"
                               Margin="0,10,0,0"
                               Appearance="Secondary"
                               HorizontalAlignment="Left"
                               Click="Search_Click" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
