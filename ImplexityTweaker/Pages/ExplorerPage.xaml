<Page x:Class="ImplexityTweaker.Pages.ExplorerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Explorer"
      Foreground="{DynamicResource App.Text}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Проводник и Рабочий стол"
                       FontSize="32"
                       FontWeight="Bold" />
            <TextBlock Text="Параметры отображения и поведения проводника и ярлыков на рабочем столе."
                       Foreground="{DynamicResource App.TextMuted}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,16"
                       FontSize="14" />

            <ui:Card>
                <StackPanel Margin="16">
                    <ui:ToggleSwitch x:Name="HiddenToggle" Content="Показывать скрытые файлы и папки" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="SystemToggle" Content="Показывать защищенные системные файлы" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="ExtToggle" Content="Показывать расширения файлов" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="ThisPcToggle" Content="Открывать «Этот компьютер» вместо «Главная»" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Content="Обновить" Appearance="Secondary" Click="Refresh_Click" Margin="0,0,8,0" />
                        <ui:Button Content="Применить" Appearance="Primary" Click="Apply_Click" />
                        <ui:Button Content="Перезапустить проводник" Appearance="Transparent" Margin="8,0,0,0" Click="RestartExplorer_Click" />
                    </StackPanel>
                    <ui:Button Content="Сбросить к значениям по умолчанию"
                               Appearance="Transparent"
                               HorizontalAlignment="Left"
                               Margin="0,10,0,0"
                               Click="ResetDefaults_Click" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
