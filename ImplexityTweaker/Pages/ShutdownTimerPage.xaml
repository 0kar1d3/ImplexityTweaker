<Page x:Class="ImplexityTweaker.Pages.ShutdownTimerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Shutdown"
      Foreground="{DynamicResource App.Text}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Таймер выключения" FontSize="32" FontWeight="Bold" />
            <TextBlock Text="Планирование выключения или перезагрузки по таймеру."
                       Foreground="{DynamicResource App.TextMuted}"
                       Margin="0,8,0,16"
                       TextWrapping="Wrap" />

            <ui:Card>
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Через (мин):" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="MinutesBox" Width="80" Text="30" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <ui:Button Content="Выключить ПК" Appearance="Primary" Click="Shutdown_Click" Margin="0,0,8,0" />
                        <ui:Button Content="Перезагрузка" Appearance="Secondary" Click="Reboot_Click" Margin="0,0,8,0" />
                        <ui:Button Content="Отмена" Appearance="Transparent" Click="Abort_Click" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
