<Page x:Class="ImplexityTweaker.Pages.PersonalizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Personalization"
      Foreground="{DynamicResource App.Text}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Персонализация" FontSize="32" FontWeight="Bold" />
            <TextBlock Text="Эффекты интерфейса и панель задач."
                       Foreground="{DynamicResource App.TextMuted}"
                       Margin="0,8,0,16"
                       TextWrapping="Wrap" />

            <ui:Card>
                <StackPanel Margin="16">
                    <ui:ToggleSwitch x:Name="TransparencyToggle" Content="Выключить прозрачность" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="EndTaskToggle" Content="Кнопка «Завершить задачу» на панели задач (Windows 11)" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="SmallWindowButtonsToggle" Content="Включить маленькие кнопки окон" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="DisableLockScreenBlurToggle" Content="Выключить размытые на экране блокировки" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="DarkThemeToggle" Content="Включить тёмную тему" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="SuperDetailedInfoToggle" Content="Включить суперподробные сведения о системе" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="DisableBootLogoToggle" Content="Выключить логотип Windows в загрузчике системы" Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="DisableBootAnimationToggle" Content="Выключить анимацию в загрузке системы" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Content="Применить" Appearance="Primary" Click="Apply_Click" Margin="0,0,8,0" />
                        <ui:Button Content="Параметры панели задач" Appearance="Secondary" Click="Settings_Click" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
