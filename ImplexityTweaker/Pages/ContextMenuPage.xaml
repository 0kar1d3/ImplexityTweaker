<Page x:Class="ImplexityTweaker.Pages.ContextMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="ContextMenu"
      Foreground="{DynamicResource App.Text}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Контекстное меню" FontSize="32" FontWeight="Bold" />
            <TextBlock Text="Настройка пунктов контекстного меню Windows. Некоторые изменения требуют перезапуска проводника."
                       Foreground="{DynamicResource App.TextMuted}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,16" />

            <ui:Card>
                <StackPanel Margin="16">
                    <ui:ToggleSwitch x:Name="OldContextMenuToggle"
                                       Content="Включить старое контекстное меню"
                                       Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="RemoveContextDelayToggle"
                                       Content="Убрать задержку контекстного меню"
                                       Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="OpenInTerminalToggle"
                                       Content="Открыть в терминале"
                                       Margin="0,0,0,12" />

                    <TextBlock Text="Поделиться"
                               FontWeight="SemiBold"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource App.Text}" />
                    <ui:ToggleSwitch x:Name="ShareToggle"
                                       Content=""
                                       Margin="0,0,0,12" />

                    <TextBlock Text="Восстановить прежнюю версию"
                               FontWeight="SemiBold"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource App.Text}" />
                    <ui:ToggleSwitch x:Name="RestoreOldVersionToggle"
                                       Content=""
                                       Margin="0,0,0,12" />

                    <TextBlock Text="Отправить"
                               FontWeight="SemiBold"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource App.Text}" />
                    <ui:ToggleSwitch x:Name="SendToggle"
                                       Content=""
                                       Margin="0,0,0,12" />

                    <TextBlock Text="Копировать как путь"
                               FontWeight="SemiBold"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource App.Text}" />
                    <ui:ToggleSwitch x:Name="CopyPathToggle"
                                       Content=""
                                       Margin="0,0,0,12" />

                    <TextBlock Text="Закрепить"
                               FontWeight="SemiBold"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource App.Text}" />
                    <ui:ToggleSwitch x:Name="PinStartToggle"
                                       Content="Закрепить на начальном экране"
                                       Margin="0,0,0,12" />
                    <ui:ToggleSwitch x:Name="PinTaskbarToggle"
                                       Content="Закрепить на панели задач"
                                       Margin="0,0,0,12" />

                    <ui:Button Content="Применить"
                               Appearance="Primary"
                               HorizontalAlignment="Left"
                               Margin="0,10,0,0"
                               Click="Apply_Click" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
