<Page x:Class="ImplexityTweaker.Pages.WindowsComponentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Components"
      Foreground="{DynamicResource App.Text}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Компоненты Windows" FontSize="32" FontWeight="Bold" />
            <TextBlock Text="Включение и отключение компонентов через стандартные средства системы."
                       Foreground="{DynamicResource App.TextMuted}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,16" />

            <ui:Card>
                <StackPanel Margin="16">
                    <ui:Button Content="Открыть «Компоненты Windows»"
                               Appearance="Primary"
                               HorizontalAlignment="Left"
                               Click="OptionalFeatures_Click" />
                    <ui:Button Content="Программы и компоненты (appwiz.cpl)"
                               Margin="0,10,0,0"
                               Appearance="Secondary"
                               HorizontalAlignment="Left"
                               Click="Appwiz_Click" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
