<Page x:Class="ImplexityTweaker.Pages.UwpAppsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Uwp"
      Foreground="{DynamicResource App.Text}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Удаление UWP приложений" FontSize="32" FontWeight="Bold" />
            <TextBlock Text="Удаление выполняется для текущего пользователя. Некоторые пакеты защищены системой."
                       Foreground="{DynamicResource App.TextMuted}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,16" />

            <ui:Card>
                <StackPanel Margin="16">
                    <ComboBox x:Name="PackageBox" MinWidth="420" />
                    <TextBlock Text="Или введите ID пакета вручную (пример: Microsoft.WindowsCamera):"
                               Margin="0,10,0,4"
                               Foreground="{DynamicResource App.TextMuted}" />
                    <TextBox x:Name="ManualPackageBox" MinWidth="420" />
                    <ui:Button Content="Удалить выбранный пакет"
                               Margin="0,12,0,0"
                               Appearance="Primary"
                               HorizontalAlignment="Left"
                               Click="Remove_Click" />
                    <ui:Button Content="Обновить список популярных пакетов"
                               Margin="0,8,0,0"
                               Appearance="Transparent"
                               HorizontalAlignment="Left"
                               Click="ReloadList_Click" />
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
